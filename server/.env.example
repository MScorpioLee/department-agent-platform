# 复制为 server/.env(已被 .gitignore 忽略),按需修改。
# 优先级:真实环境变量 > 本文件 > 代码默认值。变量名都带 AGENT_ 前缀。

# ===== 数据库(本地 / 远程二选一)=====
# 本地 SQLite(默认,免装额外驱动):
AGENT_DATABASE_URL=sqlite+aiosqlite:///./server.db
# 远程 PostgreSQL(需先 uv pip install -e '.[postgres]' 装 asyncpg):
# AGENT_DATABASE_URL=postgresql+asyncpg://agent:secret@192.168.1.50:5432/agent
# 生产建议关掉自动建表,改用 alembic upgrade head:
# AGENT_AUTO_CREATE_TABLES=false

# ===== 认证 / 管理员 =====
AGENT_API_KEY=change-me
AGENT_ENROLLMENT_TOKEN=change-me
AGENT_ADMIN_USERNAME=admin
AGENT_ADMIN_PASSWORD=change-me

# ===== 模型网关 =====
AGENT_MODELS_CONFIG_PATH=models.yaml
