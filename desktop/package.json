{
  "name": "department-agent-desktop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs && tauri icon assets/icon-source.png",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:mac": "tauri build --bundles app,dmg",
    "build:windows": "tauri build --bundles msi,nsis",
    "build:linux": "tauri build --bundles appimage,deb",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4"
  }
}
