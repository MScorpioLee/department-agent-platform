# Public reverse-proxy host. Use ":80" for a local HTTP smoke test, or a real
# domain such as "agent.example.com" for automatic Caddy TLS.
PUBLIC_HOST=agent.example.com

POSTGRES_DB=agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=change-me-postgres-password

AGENT_API_KEY=change-me-server-api-key
AGENT_ENROLLMENT_TOKEN=change-me-runner-enrollment-token
AGENT_ADMIN_USERNAME=admin
AGENT_ADMIN_PASSWORD=change-me-admin-password

# Used by deploy/models.yaml. Leave empty only if chat/model features are not enabled.
DEEPSEEK_API_KEY=change-me-deepseek-key

# Optional: set only when browser WS should use a different public endpoint.
# When empty, the WebUI falls back to the current page origin and Caddy proxies /ws/client.
NEXT_PUBLIC_AGENT_WS_URL=
